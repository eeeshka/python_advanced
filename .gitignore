# Скомпилированные Python файлы
# Python автоматически создает .pyc файлы при импорте модулей
*.pyc

# Папка с кэшем Python
# Содержит скомпилированные байт-код файлы для ускорения импорта
__pycache__/

# Файлы с переменныим окружением
# Могут содержать секретные данные (API ключи, пароли)
.env

# вирт окруж Python
# Содержит установленные пакеты, не нужно хранить в репозитории
venv/

# Лог файлы
# Генерируются приложением, не нужно хранить в репозитории
*.log

# Папка с собранными пакетами
# Создается при сборке пакета для распространения
dist/

# Папка со сборкой проекта
# Содержит временные файлы сборки
build/

.idea/workspace.xml.idea/
